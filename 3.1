#include <Arduino.h>
#include <WiFi.h>
#include <WebServer.h>
#include "pagina.h" // Nuestro archivo HTML limpio protegido con include guards

// --- Credenciales para modo Estación (STA) - Tu red local ---
const char* ssid = "TU_SSID_AQUI";
const char* password = "TU_PASSWORD_AQUI";

// --- Credenciales para modo Punto de Acceso (AP) - La red que creará la ESP32 ---
const char* ap_ssid = "ESP32_MiPractica";
const char* ap_password = "password123"; // La contraseña del AP debe tener al menos 8 caracteres

WebServer server(80);

void handle_root() {
  server.send(200, "text/html", HTML_PAGINA);
}

void setup() {
  Serial.begin(115200);
  Serial.println("\n--- Iniciando ESP32 ---");

  // 1. Configuramos el modo Estación (STA) e intentamos conectar
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);
  Serial.print("Intentando conectar a la red: ");
  Serial.println(ssid);

  // Variable para controlar el tiempo/intentos
  int intentos = 0;
  const int MAX_INTENTOS = 20; // 20 intentos de 500ms = 10 segundos de espera

  // Esperamos mientras no conecte Y no nos pasemos del límite de intentos
  while (WiFi.status() != WL_CONNECTED && intentos < MAX_INTENTOS) {
    delay(500);
    Serial.print(".");
    intentos++;
  }
  Serial.println(); // Salto de línea limpio

  // 2. Evaluamos el resultado: ¿Se conectó o se agotó el tiempo?
  if (WiFi.status() == WL_CONNECTED) {
    // ¡Éxito en modo STA!
    Serial.println("Conexión WiFi (STA) exitosa \252");
    Serial.print("Direccion IP (STA): ");
    Serial.println(WiFi.localIP()); 
  } else {
    // ¡Fallo o Timeout! Levantamos el modo AP
    Serial.println("Timeout: No se pudo conectar a la red WiFi externa.");
    Serial.println("Cambiando a modo Access Point (AP)...");
    
    // Desconectamos lo anterior y cambiamos de modo
    WiFi.disconnect();
    WiFi.mode(WIFI_AP);
    
    // Iniciamos el Punto de Acceso
    WiFi.softAP(ap_ssid, ap_password);
    
    Serial.println("Punto de Acceso (AP) iniciado con exito \252");
    Serial.print("Nombre de la red (SSID): ");
    Serial.println(ap_ssid);
    Serial.print("Direccion IP del AP: ");
    Serial.println(WiFi.softAPIP()); // Por defecto en ESP32 suele ser 192.168.4.1
  }

  // 3. Iniciamos el servidor web (sin importar en qué modo estemos)
  server.on("/", handle_root);
  server.begin();
  Serial.println("Servidor HTTP iniciado en el puerto 80.");
}

void loop() {
  server.handleClient();
}
